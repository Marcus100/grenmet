# =======================
# Monorepo .gitignore
# OS, editor, and IDE patterns live in ~/.gitignore_global
# =======================

# =======================
# Environment Variables
# =======================
# Ignore real env files, but allow committed templates.
.env
.env.*
!.env.example
!.env.*.example

# =======================
# Python
# =======================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# Python testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =======================
# Node.js / JavaScript
# =======================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# pnpm content-addressable store — lands in-repo inside the devcontainer
# (bind-mount is on a different fs than container home, so pnpm co-locates
# the store here for hardlinking). Never commit it.
.pnpm-store/

# Package manager locks (choose one per project)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Yarn v2+
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*

# =======================
# Next.js
# =======================
.next/
out/
.vercel

# =======================
# Build outputs
# =======================
build/
!apps/api/fastapi/email-templates/build/
dist/
*.tsbuildinfo

# =======================
# Testing
# =======================
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# =======================
# Docker
# =======================
# Local Docker override files (if not committed)
# docker-compose.local.yml

# =======================
# Logs
# =======================
*.log
logs/

# =======================
# Security
# =======================
*.pem
*.key
secrets/

# =======================
# Misc
# =======================
*.bak
*.tmp
*.temp

# =======================
# Programme management docs
# Sensitive governance documents (TOR, progress reports, weekly logs).
# ROADMAP.md will be committed when ready for public visibility.
# docs/reports/ contains the TOR, progress reports, and roadmap — all gitignored.
# =======================
docs/reports/
artifacts/


# =======================
# Personal inbox files dropped at repo root (PDFs, screenshots, chat images).
# Root-scoped only — legitimate assets under packages/, geonetcast/, etc. are
# unaffected. Keep the workspace root clean; move real docs into docs/.
# =======================
/*.pdf
/*.png
/*.jpg
/*.jpeg


# =======================
# Vendored GMS ops apps (SURFACE CDMS, wis2box) — see VENDORED.md
# Runtime data and real env files stay out; *.example templates are committed.
# =======================
/surface/data/
/surface/backup_restore_dumps/
/surface/api/production.env
/wis2box/wis2box.env

# =======================
# Kubb generated SDK policy
# =======================
# This repository commits generated SDK code from packages/api-client.
!packages/api-client/src/gen/
!packages/api-client/src/gen/**

# Turborepo
.turbo/*
!.turbo/config.json

# Agent local settings — per-machine overrides, never commit
.claude/settings.local.json


next-shadcn-admin-dashboard-baseui/

# MBIA scraped WordPress source material (218MB, reference only)
apps/web/mbia/.source/
