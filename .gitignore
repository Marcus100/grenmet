# =======================
# Monorepo .gitignore
# =======================

# =======================
# OS Generated Files
# =======================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# =======================
# IDE / Editor
# =======================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# =======================
# Environment Variables
# =======================
# Ignore all .env files
.env
.env.*
# But allow all .example files (templates)

!.env.example

# Explicitly ignore actual env files (not examples)
.env.local
.env.staging
.env.prod

# =======================
# Python
# =======================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# Python testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =======================
# Node.js / JavaScript
# =======================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Package manager locks (choose one per project)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Yarn v2+
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*

# =======================
# Next.js
# =======================
.next/
out/
.vercel

# =======================
# Build outputs
# =======================
build/
dist/
*.tsbuildinfo

# =======================
# Testing
# =======================
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# =======================
# Docker
# =======================
# Local Docker override files (if not committed)
# docker-compose.local.yml

# =======================
# Logs
# =======================
*.log
logs/

# =======================
# Security
# =======================
*.pem
*.key
secrets/

# =======================
# Misc
# =======================
*.bak
*.tmp
*.temp

# =======================
# Kubb generated SDK policy
# =======================
# This repository commits generated SDK code from packages/api-client.
!packages/api-client/src/gen/
!packages/api-client/src/gen/**

# Turborepo
.turbo/*
!.turbo/config.json
