x)(n.h3,{children:\"Actions in alert phase\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Sensitize all staff on duty and initiate a tropical cyclone log.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Inform Airport Management, Disaster Management Agency, and relevant authorities.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Highlight the system in radio and television weather broadcasts.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Test communication equipment.\"}),`\n`]}),`\n`,(0,e.jsx)(n.h3,{children:\"Forecaster continuity requirements\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Properly file all issued bulletins.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Ensure analyses of surface and 850 mb charts reflect the local situation.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Outgoing shift must comprehensively brief incoming shift.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Ensure all model-monitoring tasks are current.\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{id:\"watch-phase\",children:\"Watch phase\"}),`\n`,(0,e.jsx)(n.p,{children:\"If conditions indicate likely tropical storm or hurricane impacts within 48 hours, establish Watch Phase.\"}),`\n`,(0,e.jsx)(n.h3,{children:\"Actions in watch phase\"}),`\n`,(0,e.jsxs)(n.ul,{children:[`\n`,(0,e.jsx)(n.li,{children:\"Continue all Alert Phase actions.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Have two observers on each shift.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Coordinate with Trinidad Meteorological Services (TTPP) on progress, forecasts, and conclusions for Grenada.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Display and update forecast track and strike possibilities.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Ensure timely plotting of hourly observations by assistants.\"}),`\n`,(0,e.jsx)(n.li,{children:\"Maintain regular interaction with Disaster Management Agency officials and media.\"}),`\n`]}),`\n`,(0,e.jsx)(n.h2,{id:\"warning-phase\",children:\"Warning phase\"}),`\n`,(0,e.jsx)(n.p,{children:\"If tropical storm or hurricane conditions are likely 