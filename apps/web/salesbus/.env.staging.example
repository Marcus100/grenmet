# ===========================================
# Next.js Web App - Staging Environment
# ===========================================
# This file is used for staging deployments
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ===========================================

# ========= Environment =========
NODE_ENV=production

# ========= API Configuration =========
# Backend API URL for staging
NEXT_PUBLIC_API_URL=https://staging.api.barrels.gd

# ========= App Configuration =========
NEXT_PUBLIC_APP_NAME=Salesbus
NEXT_PUBLIC_APP_VERSION=0.1.0

# ========= Feature Flags =========
# Staging-specific feature flags
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ========= Developer Notes =========
# Staging Deployment:
# - API URL points to staging backend
# - Analytics enabled for staging monitoring
# - Debug mode disabled
