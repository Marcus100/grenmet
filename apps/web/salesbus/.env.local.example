# ===========================================
# Next.js Web App - Local Development Environment
# ===========================================
# Copy this file to .env.local and update values as needed:
#   cp .env.local.example .env.local
#
# Note: Next.js uses .env.local for local development
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ===========================================

# ========= Environment =========
NODE_ENV=development

# ========= API Configuration =========
# Backend API URL (must start with NEXT_PUBLIC_ to be exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ========= App Configuration =========
# App name and version
NEXT_PUBLIC_APP_NAME=Salesbus
NEXT_PUBLIC_APP_VERSION=0.1.0

# ========= Feature Flags =========
# Enable/disable features in development
NEXT_PUBLIC_ENABLE_DEBUG=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ========= Developer Notes =========
# Local Development Setup:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Update NEXT_PUBLIC_API_URL if your API runs on a different port
# 3. Start development server: pnpm dev
#
# Access Services:
# - Web App: http://localhost:3000
# - API: http://localhost:8000
