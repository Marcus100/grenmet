# ===========================================
# Next.js Web App - Production Environment
# ===========================================
# This file is used for production deployments
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ===========================================

# ========= Environment =========
NODE_ENV=production

# ========= API Configuration =========
# Backend API URL for production
NEXT_PUBLIC_API_URL=https://api.barrels.gd

# ========= App Configuration =========
NEXT_PUBLIC_APP_NAME=Salesbus
NEXT_PUBLIC_APP_VERSION=0.1.0

# ========= Feature Flags =========
# Production-specific feature flags
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ========= Developer Notes =========
# Production Deployment:
# - API URL points to production backend
# - Analytics enabled for production monitoring
# - Debug mode disabled for security
