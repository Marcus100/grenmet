azines. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Connectivity\"}),\" \\u2013 Complimentary Wi-Fi and internet access. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Business Essentials\"}),\" \\u2013 Local calls, fax, photocopying, and conference facilities. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Charging Stations\"}),\" \\u2013 Convenient charging outlets are available throughout the lounge.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Conditions of Use\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"\\u2708 Maximum stay is \",(0,n.jsx)(e.strong,{children:\"three (3) hours\"}),\" . Access may be restricted due to space constraints. \\u2708 Complimentary alcoholic beverages are limited to \",(0,n.jsx)(e.strong,{children:\"two (2) drinks per person\"}),\" . Additional drinks are subject to payment. \\u2708 Complimentary alcoholic beverages are limited to \",(0,n.jsx)(e.strong,{children:\"local beer or wine only\"}),\" . \\u2708 Children under \",(0,n.jsx)(e.strong,{children:\"three (3) years\"}),\" are admitted free when accompanied by an adult. All children must be accompanied by an adult at all times. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Smart casual attire\"}),\" is required at all times.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Methods of Payment\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"\\u2708 \",(0,n.jsx)(e.strong,{children:\"Credit Cards\"}),\" \\u2013 We accept VISA, MasterCard, and other major credit cards. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Lounge Programme Cards\"}),\" \\u2013 Priority Pass, Lounge Pair, and LoungeKey cards are accepted. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Cash\"}),\" \\u2013 Walk-in customers are welcome to pay in cash (\",(0,n.jsx)(e.strong,{children:\"US$30.00 / XCD$80.00\"}),\" for a three (3) hour stay).\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Fees\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"\\u2708 \",(0,n.jsx)(e.strong,{children:\"Executive Lounge Access Voucher\"}),\" \\u2013 US$30.00 / XCD$80.00 for a three (3) hour stay. \\u2708 \",(0,n.jsx)(e.strong,{children:\"Annual Individual Membership\"}),\" (One (1) person plus one (1) companion) \\u2013 US$500.00 / XCD$1,350.00.\"]}),`\n`,(0,n.jsx)(e.h3,{children:\"Meeting Spaces\"}),`\n`,(0,n.jsxs)(e.p,{children:[\"\\u2708 The Executive Lounge can be rented for special events and groups at a one-off cost of \",(0,n.jsx)(e.strong,{children:\"US$400.00 / XCD$1,080.00\"}),\" for three (3) hours. \\u2708 Additional charges may apply for security, janitorial services, parking services, or other special requirements.\"]}),`\n`,(0,n.jsx)(e.p,{children:\"Upgrade your travel experience and reserve your spot at the GAA Executive Lounge today!\"}),`\n`,(0,n.jsx)(e.p,{children:\"Book Here\"})]})}function h(r={}){let{wrapper:e}=r.components||{};return e?(0,n.jsx)(e,{...r,children:(0,n.jsx)(d,{...r})}):d(r)}return x(C);})();\n;return Component;"