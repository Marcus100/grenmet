"var Component=(()=>{var u=Object.create;var t=Object.defineProperty;var p=Object.getOwnPropertyDescriptor;var f=Object.getOwnPropertyNames;var g=Object.getPrototypeOf,m=Object.prototype.hasOwnProperty;var y=(r,e)=>()=>(e||r((e={exports:{}}).exports,e),e.exports),b=(r,e)=>{for(var i in e)t(r,i,{get:e[i],enumerable:!0})},s=(r,e,i,o)=>{if(e&&typeof e==\"object\"||typeof e==\"function\")for(let n of f(e))!m.call(r,n)&&n!==i&&t(r,n,{get:()=>e[n],enumerable:!(o=p(e,n))||o.enumerable});return r};var v=(r,e,i)=>(i=r!=null?u(g(r)):{},s(e||!r||!r.__esModule?t(i,\"default\",{value:r,enumerable:!0}):i,r)),A=r=>s(t({},\"__esModule\",{value:!0}),r);var c=y((T,l)=>{l.exports=_jsx_runtime});var I={};b(I,{default:()=>d});var a=v(c());function h(r){let e={a:\"a\",h2:\"h2\",h3:\"h3\",p:\"p\",...r.components};return(0,a.jsxs)(a.Fragment,{children:[(0,a.jsx)(e.h2,{children:\"Frequently Asked Questions\"}),`\n`,(0,a.jsx)(e.h3,{children:\"GENERAL TRAVEL FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Flight information is displayed on monitors in the Arrivals and Departures halls and is also available online on the airport\\u2019s website under Flight Information section. Passengers should arrive at least two (2) hours before domestic flights and three (3) hours before international flights. See where you can fly from Maurice Bishop International Airport by clicking here. Please contact your airline for assistance with minors traveling alone. A valid passport is required for international travel. Visa and validity requirements may vary by country. You can choose from several convenient check-in options, including online check-in, self-service kiosks, or assistance at the airline counter. For specific details or requirements, please contact your airline directly. Duty-free allowances vary; please check with Grenada Customs and Excise Division. Please check Flights availability and fares with the airline you wish to use. For flight reservation changes or confirmations, please contact your intended airline directly. Drop them in our charity boxes located in the Departure Hall.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"ACCESSIBILITY FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, accessible services include elevators, restrooms, escalators, and designated parking. Please contact your airline directly to request wheelchair assistance. Please inform your airline, travel agent or tour organizer of your assistance needs. Please inform your airline, travel agent or tour organizer of your assistance needs at least 48 hours before departure.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"TRAVELLING WITH ANIMALS FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, companion dogs are welcome. Please contact your airline regarding transport requirements. Please contact your airline in advance to confirm cabin pet policies and restrictions. Please check with your airline in advance if Emotional Support Animals are allowed.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"LUGGAGE STORAGE FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"MBIA does not offer luggage storage.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"SHOWER FACILITIES FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"No, shower facilities are not currently available.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"CONCESSIONS OPPORTUNITIES AT MBIA FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Please contact the GAA\\u2019s Business Development & Corporate Communications Department for leasing inquiries.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"MEETING FACILITIES AT MBIA FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, the airport does offer conference room facilities.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"SECURITY SCREENING FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Check the TSA website for updated information on permitted and prohibited items. Food is allowed. Beverages are not permitted through security. Yes, unless they are liquid substances, gels or aerosols.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"BAGGAGE FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Baggage allowance policies vary by airline. Please check directly with your airline. Contact your airline for policies regarding checked and carry-on luggage. Airlines are responsible for locating checked baggage. Passengers should file a baggage claim with their airline as soon as possible.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"WI-FI FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, free Wi-Fi is available throughout the terminal.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"AIRPORT LOUNGES FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"MBIA has three lounges including the Executive Lounge and Government VIP Lounge. Find out more about the lounges available and book online.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"RESTAURANTS & BARS FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"The airport features restaurants, caf\\xE9s, duty-free, and retail shops. Skyline Caf\\xE9, Ants Nest, Rituals Coffee House & Brizan Bar & Bites. First Class Restaurant, Sports Bar by Zander & Spice Isle Coffee.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"DUTY FREE SHOPPING FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Smoke Duty Free, Imperial Jewelers, Best Liquor Store, Colombian Emeralds and more. Tambran by Tamara & Grenada to Go. Inbound Duty-Free by Dufry.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"PARKING FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Short-term and long-term parking options are available. Please visit the parking section for updated parking rates. Currencies accepted include Eastern Caribbean Dollars, US Dollars, Euros, Canadian Dollars, Great British Pounds, Barbados Dollars. We also accept all major debit and credit cards. Yes, vehicles are permitted to pull up curbside, but ONLY for ACTIVE loading and unloading. Vehicles left unattended at the curb will be towed. The car park at MBIA is uncovered. As such, no vehicle height restrictions are in place.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"CAR RENTALS FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Hertz, J & B Auto Rentals, Y & R Car Rentals and others are available. The car rental counters are located outside of the airport Arrivals Hall. Yes, car rental services are available and can be pre-booked. Passengers have the option of either pre-booking their rental car and collecting on arrival or booking a car on the spot.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"TAXI & TOUR OPERATORS FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, taxis are available outside the arrivals area. Tour Operators are located outside the arrivals area.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"LOST & FOUND FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Please contact your airline directly regarding missing luggage. For items left on board the aircraft, please contact the airline. Contact the GAA\\u2019s Lost and Found in the Security Department. Provide exact details such as serial numbers, brand, color, receipts or duplicate keys. The owner must show valid photo ID or a passport. You can arrange for your property to be picked up by a third party or courier.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"FILMING & PHOTOGRAPHY FAQ\\u2019s\"}),`\n`,(0,a.jsxs)(e.p,{children:[\"Yes, filming and photography are allowed in approved airport locations. You can send your request to \",(0,a.jsx)(e.a,{href:\"mailto:bdcc@gaa.gd\",children:\"bdcc@gaa.gd\"}),\".\"]}),`\n`,(0,a.jsx)(e.h3,{children:\"AIRPORT TOURS FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, educational airport tours are available for school students. No, currency exchange services are not available at the airport. There are currently no ATM Machines at MBIA. Porters (Red Caps) are available in the Baggage Reclaim Hall to assist with your luggage. Smoking is allowed outside the terminal building only.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"MAIL SERVICES FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"At MBIA, you\\u2019ll find a mailbox located in the arrival concourse where travelers can send letter-sized envelopes or postcards.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"FAST TRACK / MEET & GREET SERVICE FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Yes, fast-track services are available through select providers.\"}),`\n`,(0,a.jsx)(e.h3,{children:\"FEEDBACK FAQ\\u2019s\"}),`\n`,(0,a.jsx)(e.p,{children:\"Feedback can be submitted through the website contact form or by email.\"}),`\n`,(0,a.jsx)(e.p,{children:\"No matching questions found.\"}),`\n`,(0,a.jsx)(e.p,{children:\"GENERAL TRAVEL FAQ's\"}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"How do I access flight information?\"}),\" Flight information is displayed on monitors in the Arrivals and Departures halls and is also available online on the airport\\u2019s website under Flight Information section. Flight information can also be obtained by contacting your airline directly \",(0,a.jsx)(e.a,{href:\"/\",children:\"How early should I arrive before my flight?\"}),\" Passengers should arrive at the Airport at least two (2) hours before the scheduled departure of a domestic flight and three (3) hours prior to the scheduled departure of an international flight. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What are the check-in deadlines?\"}),\" Check \\u2013 In closes one hour before departure \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which airlines are flying to and from Grenada?\"}),\" See where you can fly from the Maurice Bishop International Airport by clicking here \",(0,a.jsx)(e.a,{href:\"/\",children:\"Is there assistance for minors traveling alone?\"}),\" To obtain assistance for minors traveling alone, please contact your airline. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What ID do I need for international travel?\"}),\" For international travel a passport is required. Depending on the country there may be a requirement to have at least six months validity after your return date. Your airline should be able to confirm this for you along with any visa requirements. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What check-in options are available for my flight?\"}),\" You can choose from several convenient check-in options, including online check-in, self-service kiosks, or assistance at the airline counter. For specific details or requirements, please contact your airline directly. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What are the duty-free allowances for items brought into Grenada?\"}),\" Duty-free allowances vary; please check with Grenada Customs and Excise Division. \",(0,a.jsx)(e.a,{href:\"/\",children:\"How can I check Flights availability and prices?\"}),\" Please check Flights availability and fares with the airline you wish to use. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Can I change or confirm my flight reservation by calling the airport information desk?\"}),\" For flight reservation changes or confirmations, please contact your intended airline directly (they cannot be confirmed through general information services). \",(0,a.jsx)(e.a,{href:\"/\",children:\"What should I do with leftover currency?\"}),\" Drop them in our charity boxes located in the Departure Hall. BAGGAGE FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"What is the baggage allowance and can I bring a carry-on?\"}),\" Baggage allowance policies vary by airline. Passengers should check with their airline for specific rules regarding checked and carry-on baggage. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What are the weight/size restrictions on checked and carry-on luggage?\"}),\" Contact your airline for its policies on checked and carry-on luggage. This information can be found on the airline's website. \",(0,a.jsx)(e.a,{href:\"/\",children:\"How do I report lost or damaged baggage?\"}),\" When a checked bag does not arrive at its destination, airlines are responsible for locating the bag. Airlines have tracking systems in place to try to identify the bag\\u2019s location. Passengers should file a baggage claim with their airline as soon as possible and follow up with the airline after filing a claim and during the baggage location process. Most airlines offer baggage tracking capabilities for passengers via the carrier\\u2019s website or mobile app. The Airport does not have access to the airlines' baggage tracking systems. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What items are prohibited in checked and carry-on baggage?\"}),\" Prohibited items include flammable materials, explosives and certain sharp objects. For a full list please refer to the TSA Website \",(0,a.jsx)(e.a,{href:\"https://www.tsa.gov/travel/security-screening/whatcanibring/all\",children:\"https://www.tsa.gov/travel/security-screening/whatcanibring/all\"}),\" ACCESSIBILITY FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Are there facilities and services for passengers with disabilities?\"}),\" Yes, The airport has a variety of accessible services and facilities that are available to travelers with disabilities. This includes restrooms, elevators, escalators, restrooms, and designated parking spaces. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Can I inform the airport of my special assistance requirements?\"}),\" Please inform your airline, travel agent or tour organizer of your assistance needs. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Where do I register my special assistance requirements\"}),\" : Please inform your airline, travel agent or tour organizer of your assistance needs at least 48 hours before departure. When booking your trip, inform the travel agent of the nature of your disability and what kind of assistance you will require. Your travel agent will inform the airline with which you are travelling. If you book online, you can register on the airline's website. This will enable the airline to make all of the necessary arrangements for you to receive the desired services at Maurice Bishop International Airport, both on your departure and return, and at your destination airport. \",(0,a.jsx)(e.a,{href:\"/\",children:\"How can I get wheelchair assistance?\"}),\" To request wheelchair assistance, please reach out to your airline directly. TRAVELLING WITH ANIMALS FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Am I allowed to travel with my Service animal?\"}),\" Companion dogs are very welcome at the airport. If you are flying with an assistance animal, we advise you to contact your airline in advance to inquire about the applicable transport requirements. Depending on the airline, different rules and regulations may apply. Make sure you have all the documents and records required for your dog. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Is my pet allowed to travel with me in the aircraft cabin?\"}),\" Ask your airline in advance about whether you are allowed to take animals into the cabin and what restrictions apply. Please note that some airlines do not transport any animals in the cabin. \",(0,a.jsx)(e.a,{href:\"/\",children:\"May I travel with my Emotional Support Animal?\"}),\" If you are planning to travel with an Emotional Support Animal, please check with your airline in advance if this is allowed. There are different regulations and requirements that may vary per airline. Make sure you have all necessary documents and papers required for your animal.: If you are planning to travel with an Emotional Support Animal, please check with your airline in advance if this is allowed. There are different regulations and requirements that may vary per airline. Make sure you have all necessary documents and papers required for your animal. SECURITY SCREENING FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"What can I take through security?\"}),\" View the Transportation Security Administration\\u2019s (TSA) website for up-to-date information on permitted and prohibited items, including medications and children\\u2019s items. \",(0,a.jsx)(e.a,{href:\"https://www.tsa.gov/travel/security-screening/whatcanibring/all\",children:\"https://www.tsa.gov/travel/security-screening/whatcanibring/all\"}),\" \",(0,a.jsx)(e.a,{href:\"/\",children:\"Can I take food and beverage with me?\"}),\" Beverages are not allowed. Food is allowed, but please note that the Security Officer may need to open or unwrap your food for additional screening. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Being a transit passenger, can I take my duty-free purchased items with me?\"}),\" Yes, unless they are liquid substances, gels or aerosols. These must be packed in your checked luggage. ATM / CAMBIO FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Is there a currency exchange service available?\"}),\" No, currency exchange services are not available at the airport. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Where can I find an ATM (Automated Teller Machine) at the airport?\"}),\" There are currently no ATM Machines at MBIA PORTER SERVICE FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"I need help with my luggage. Do you offer assistance?\"}),\" Porters (Red Caps) are available in the Baggage Reclaim Hall to assist with your luggage. If you need help carrying your bags from the arrivals area to your car, they\\u2019ll be happy to assist. With prior arrangements, porters can also help transport your luggage from the curbside to the check-in counter, ensuring a smooth and convenient travel experience. WI-FI FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Is there Wi-Fi available at the airport?\"}),\" Yes, free Wi-Fi is available throughout the terminal. SMOKING FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Are there any smoking areas at Maurice Bishop International Airport?\"}),\" While there are no designated smoking areas, smoking is allowed outside the terminal building. Smoking is NOT permitted inside of the terminal building. RESTAURANTS & BARS FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"What dining and retail options are available at the airport?\"}),\" The airport features restaurants, caf\\xE9s, duty-free, and retail shops. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which restaurants are located before Security (outside the Terminal)?\"}),\" Skyline Caf\\xE9, Ants Nest, Rituals Coffee House & Brizan Bar & Bites \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which restaurants are located after Security (inside the terminal)?\"}),\" First Class Restaurant, Sports Bar by Zander & Spice Isle Coffee DUTY FREE SHOPPING FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Which shops are located before Security screening?\"}),\" Tambran by Tamara & Grenada to Go \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which shops are located after Security screening?\"}),\" Smoke Duty Free, Imperial Jewelers, Best Liquor Store, Colombian Emeralds, Ganzee, Spice It Up, Kallaloo Souvenir & Gift Shop \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which shops are in the Baggage Reclaim Hall?\"}),\" Inbound Duty-Free by Dufry \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which shops are in the Baggage Reclaim Hall?\"}),\" Inbound Duty-Free by Dufry PARKING AT THE AIRPORT FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"What parking options are available for passengers and visitors?\"}),\" Short-term and long-term parking options are available. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Which currencies are accepted?\"}),\" Currencies accepted include Eastern Caribbean Dollars, US Dollars, Euros, Canadian Dollars, Great British Pounds, Barbados Dollars. We also accept all major debit and credit cards. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What are the parking rates?\"}),\" Click here for the parking rates. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Is it still possible to drop off and pick up someone in front of a terminal?\"}),\" Yes, vehicles are permitted to pull up curbside, but ONLY for ACTIVE loading and unloading. Vehicles left unattended at the curb will be towed \",(0,a.jsx)(e.a,{href:\"/\",children:\"What are the vehicle height restrictions at MBIA car park?\"}),\" The car park at the MBIA is uncovered. As such, no vehicle height restrictions are in place. CAR RENTALS FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Which car rental companies are located at Maurice Bishop International Airport?\"}),\" There are SIX (6) car rental operators currently at the MBIA: Hertz Car Rentals, J & B Auto Rentals, Y & R Car Rentals, Maitland Car Rentals & Economy Car Rentals & True Car Rentals (Alamo / National / Enterprise) \",(0,a.jsx)(e.a,{href:\"/\",children:\"Where can you find the car rental counters?\"}),\" The car rental counters are located outside of the airport Arrivals Hall. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Can I pre-book a rental vehicle at the airport?\"}),\" Yes, car rental services are available and can be pre-booked. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Can I pre-book a rental vehicle?\"}),\" Passengers have the option of either pre-booking their rental car and collecting on arrival or booking a car on the spot. TAXI & TOUR OPERATORS FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Are taxis available at the airport?\"}),\" Yes, taxis are available outside the arrivals area. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Where can I locate the Tour Operators within the airport?\"}),\" Tour Operators are located outside the arrivals area MAIL SERVICES FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Are mail services available at MBIA?\"}),\" At MBIA, you\\u2019ll find a mailbox located in the arrival concourse where travelers can send letter-sized envelopes or postcards. FAST TRACK / MEET & GREET SERVICE FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Does MBIA offer fast-track services for expedited processing?\"}),\" Yes, fast-track services are available through select providers. FILMING & PHOTOGRAPHY AT MBIA FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Can I do a photoshoot or film at Maurice Bishop International airport?\"}),\" Yes, Photography and Filming is allowed, but only allowed for selected airport locations, which need to be approved by the commercial team. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What should I do if I want to do photography or filming at Maurice Bishop International Airport?\"}),\" You can send an email with your request to \",(0,a.jsx)(e.a,{href:\"mailto:bdcc@gaa.gd\",children:\"bdcc@gaa.gd\"}),\" LOST & FOUND FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"My luggage did not arrive. Who can I contact?\"}),\" All luggage is handled by the airlines directly. Please contact your airline. \",(0,a.jsx)(e.a,{href:\"/\",children:\"Who can I contact?\"}),\" For items left on board the aircraft, please contact the airline. \",(0,a.jsx)(e.a,{href:\"/\",children:\"I have lost or found an item at the security checkpoint or in the common areas of the airport. Who can I contact?\"}),\" If you left an item at a security checkpoint or in the common areas of the airport, contact the GAA\\u2019s Lost and Found in the Security Department. Please contact us by filling in and submitting this form. \",(0,a.jsx)(e.a,{href:\"/\",children:\"How can I prove that the lost item is my property?\"}),\" By providing exact details, e.g. device ID numbers, serial numbers, etc., details on the color, material or brand, you will help with the search for your lost property. Receipts, other documents or a duplicate key can also be useful. \",(0,a.jsx)(e.a,{href:\"/\",children:\"What do I have to bring with me when picking up an item I have identified?\"}),\" When picking up items, the owner must show valid photo ID or a passport. \",(0,a.jsx)(e.a,{href:\"/\",children:\"I cannot pick up my property in person. What can I do?\"}),\" You can arrange for your property to be picked up by a third party or a courier. CONCESSIONS OPPORTUNITIES AT MBIA FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"What is the process for securing a retail space within the terminal?\"}),\" Please contact the GAA\\u2019s Business Development & Corporate Communications (BDCC) Department for leasing inquiries. MEETING FACILITIES AT MBIA FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Is there a conference room available for use at the airport?\"}),\" Yes, the airport does offer conference room facilities. AIRPORT TOURS FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Does the airport offer tours?\"}),\" Yes. The airport provides educational tours specifically designed for school students. For more details or to schedule a tour, please contact the Business Development and Corporate Communications team at \",(0,a.jsx)(e.a,{href:\"mailto:bdcc@gaa.gd\",children:\"bdcc@gaa.gd\"}),\" LUGGAGE STORAGE FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Does MBIA offer luggage storage?\"}),\" MBIA does not offer luggage storage. CUSTOMER FEEDBACK FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"How can I provide feedback or file a complaint?\"}),\" You can share your comments or file a complaint through any of the following channels: \\u2022 Online: Complete our Contact Form on the GAA website. \\u2022 Email: Send us your feedback at \",(0,a.jsx)(e.a,{href:\"mailto:bdcc@gaa.gd\",children:\"bdcc@gaa.gd\"}),\". \\u2022 In Person: Visit the Duty Manager\\u2019s Office at the airport and fill out a Customer Complaints Form. \",(0,a.jsx)(e.a,{href:\"/\",children:\"How may \\u0399 provide feedback?\"}),\" We welcome all feedback to improve our services. To say thank you or to make a complaint, please complete our Customer Satisfaction Questionnaire and we will look any issue you have raised and respond to you, if you wish. SHOWER FACILITIES FAQ's\"]}),`\n`,(0,a.jsxs)(e.p,{children:[(0,a.jsx)(e.a,{href:\"/\",children:\"Are there shower facilities available at the airport?\"}),\" No, shower facilities are not currently available.\"]})]})}function d(r={}){let{wrapper:e}=r.components||{};return e?(0,a.jsx)(e,{...r,children:(0,a.jsx)(h,{...r})}):h(r)}return A(I);})();\n;return Component;"