# Database (use either DATABASE_URL or DB_URL; drizzle-kit and db client accept both)
DATABASE_URL=postgresql://user:password@localhost:5432/wxproducts
# DB_URL=postgresql://user:password@localhost:5432/wxproducts

# Sentry error tracking (optional locally — get DSN from grenmet.sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# PostHog analytics (https://posthog.com → Project Settings → Project token)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
