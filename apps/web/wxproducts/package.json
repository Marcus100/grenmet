    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:ci": "biome ci .",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
