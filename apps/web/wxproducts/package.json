{
  "name": "@grenmet/web-wxproducts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3005",
    "build": "next build",
    "start": "next start --port 3005",
    "lint": "biome lint .",
