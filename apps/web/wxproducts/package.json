    "react-dom": "catalog:",
    "zod": "catalog:",
    "@t3-oss/env-nextjs": "catalog:"
  },
  "devDependencies": {
    "@grenmet/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@total-typescript/ts-reset": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "catalog:",
    "playwright": "^1.58.2",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
