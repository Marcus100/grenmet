# FastAPI backend
AUTH_API_URL=http://localhost:8000
AUTH_API_V1_STR=/api/v1

# Session cookie (must match admin-gms)
SESSION_COOKIE_NAME=grenmet_session

# Allow redirects back to any local app (comma-separated)
# 3001=admin-gms, 3002=wxwatch, 3003=hurricaneplan, 3004=spicewx, 3005=wxproducts, 3006=hr, 3007=salesbus
AUTH_ALLOWED_RETURN_HOSTS=localhost:3001,localhost:3002,localhost:3003,localhost:3004,localhost:3005,localhost:3006,localhost:3007

# Sentry error tracking (optional locally — get DSN from grenmet.sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# PostHog analytics (https://posthog.com → Project Settings → Project token)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
