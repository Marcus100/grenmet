RESEND_API_KEY=dev-placeholder
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shared auth app (sign-in UI)
AUTH_APP_URL=http://localhost:3000

# FastAPI backend (server-side session exchange)
AUTH_API_URL=http://localhost:8000
AUTH_API_V1_STR=/api/v1

# Session cookie (must match auth app)
SESSION_COOKIE_NAME=grenmet_session

# Run admin-gms on port 3001 (auth app uses 3000)
PORT=3001

# Sentry error tracking (optional locally — get DSN from grenmet.sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# PostHog analytics (https://posthog.com → Project Settings → Project token)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
