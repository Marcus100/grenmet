{
  "name": "@grenmet/web-admin",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:ci": "biome ci .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:wxwatch:generate": "drizzle-kit generate --config=drizzle.wxwatch.config.ts",
    "db:wxwatch:migrate": "dotenv -e .env.local -- drizzle-kit migrate --config=drizzle.wxwatch.config.ts",
    "db:wxproducts:generate": "drizzle-kit generate --config=drizzle.wxproducts.config.ts",
    "db:wxproducts:migrate": "dotenv -e .env.local -- drizzle-kit migrate --config=drizzle.wxproducts.config.ts",
    "pdf:wxproducts:morning": "node scripts/wxproducts-export-pdf.mjs /wxproducts/pdf/morning artifacts/wxproducts/pdf/morning.pdf"
  },
