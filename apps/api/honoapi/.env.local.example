# ===========================================
# HonoAPI - Local Development Environment
# ===========================================
# Copy this file to .env and update values as needed:
#   cp .env.local.example .env
# ===========================================

# ========= Environment =========
NODE_ENV=development
ENVIRONMENT=local

# ========= Server Configuration =========
# Server port and host
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ========= API Configuration =========
# API prefix for routes
API_PREFIX=/api/v1

# ========= Database =========
# If connecting to shared database:
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://app:changethis@db:5432/app

# ========= Developer Notes =========
# Local Development Setup:
# 1. Copy this file: cp .env.local.example .env
# 2. Update DATABASE_URL if using different database credentials
# 3. Start development server: pnpm dev
#
# Access Services:
# - HonoAPI: http://localhost:4000
