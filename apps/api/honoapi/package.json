{
  "name": "@grenmet/api-hono",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "hono": "^4.11.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@grenmet/tsconfig": "workspace:*",
    "@total-typescript/ts-reset": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.0.17",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.17"
  }
}
