# ===========================================
# FastAPI Backend - Local Development Environment
# ===========================================
# Copy this file to .env.local and update values as needed:
#   cp .env.local.example .env.local
#
# For production, use stronger secrets generated with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# ========================================z===

# ========= Environment Selection =========
## One of: local | staging | production
ENVIRONMENT=local

# ========= Project Identity =========
# Human-readable project title
PROJECT_NAME="Grenmet API"

# Stack name used in Traefik labels and Docker Compose
# Keep short, lowercase, use dashes/underscores
STACK_NAME=grenmet-api

# ========= Domains and Hosts =========
# Root domain used for routing
# - local: localhost (or localhost.tiangolo.com for local Traefik HTTPS)
# - staging: staging.api.weather.gd
# - production: api.weather.gd
DOMAIN=localhost

# Public client origin used in emails and CORS
# Leave empty for backend-only development
FRONTEND_HOST=http://localhost:3000

# ========= API Configuration =========
# API version prefix (default: /api/v1)
API_V1_STR=/api/v1

# CORS origins accepted by the backend
# Comma-separated list or JSON array format
# Backend-only defaults allow direct API access
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003","http://localhost:3004","http://localhost:8000","http://localhost:5173","http://172.22.0.1:3000"]
# ========= Security =========
# Generate a strong secret (REQUIRED for production):
#   openssl rand -base64 32
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# For local dev, "changethis" is acceptable but will show warnings
SECRET_KEY=changethis

# JWT token expiration (in minutes)
# Default: 60 * 24 * 8 = 11520 minutes (8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Bootstrap superuser for first-time initialization
FIRST_SUPERUSER=admin@weather.gd
FIRST_SUPERUSER_PASSWORD=changethis

# ========= Database (PostgreSQL) =========
# In Docker Compose, 'grenmet-postgres' is the container name defined in infra/docker/docker-compose.yml
# Change only if using an external DB host
POSTGRES_SERVER=grenmet-postgres
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=changethis

# ========= Email Configuration =========
# Email provider preference: Resend (recommended) or SMTP

# Resend API Key (preferred for staging/production)
# If RESEND_API_KEY is set, backend will use Resend
# If not set, backend falls back to SMTP settings below
RESEND_API_KEY=

# SMTP Configuration (fallback or for local MailCatcher)
# For local dev with MailCatcher, these are overridden in docker-compose.override.yml
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
SMTP_SSL=False

# Email sender configuration
EMAILS_FROM_EMAIL=noreply@weather.gd
EMAILS_FROM_NAME=

# Email reset token expiration (in hours)
# Default: 48 hours
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# Test email recipient (for email testing endpoints)
EMAIL_TEST_USER=test@weather.gd

# ========= Observability =========
# Sentry DSN for error tracking
# Keep empty if not used; must be either empty or a valid DSN URL
SENTRY_DSN=

# ========= Container Image Names =========
# Docker image registry configuration (for CI/CD)
# Local defaults (no registry):
DOCKER_IMAGE_BACKEND=backend
# Optional tagging (CI may set TAG, e.g., git sha or semver)
# TAG=latest

# ========= Traefik (Reverse Proxy) =========
# For docker-compose.traefik.yml (production/staging Traefik):
# EMAIL is required by Let's Encrypt for SSL certificates
# USERNAME/HASHED_PASSWORD secure the Traefik dashboard
# Generate bcrypt hash: htpasswd -nbB admin 'yourpassword'
# Or use online bcrypt generator: https://bcrypt-generator.com/
EMAIL=
USERNAME=
HASHED_PASSWORD=

# ========= Developer Notes =========
# Local Development Setup:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Update SECRET_KEY, POSTGRES_PASSWORD, FIRST_SUPERUSER_PASSWORD
# 3. Start services: docker compose watch
#
# Access Services:
# - API Docs: http://localhost:8000/docs
# - Health Check: http://localhost:8000/api/v1/utils/health-check/
# - Database UI (Adminer): http://localhost:8080
# - Email Testing (MailCatcher): http://localhost:1080
# - Traefik Dashboard: http://localhost:8090
#
# MailCatcher Configuration:
# For local development, SMTP settings are automatically configured
# in docker-compose.override.yml to use MailCatcher:
#   SMTP_HOST=mailcatcher
#   SMTP_PORT=1025
#   SMTP_TLS=false
