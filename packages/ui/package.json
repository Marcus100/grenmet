{
  "name": "@grenmet/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./src/components/*.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts"
    },
    "./styles/*": "./src/styles/*.css"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:ci": "biome ci ."
  },
  "dependencies": {
    "@base-ui-components/react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*",
    "tailwindcss": "*"
  },
  "devDependencies": {
    "@grenmet/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
