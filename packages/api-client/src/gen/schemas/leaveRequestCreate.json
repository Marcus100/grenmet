{
  "properties": {
    "department_id": { "type": "string", "title": "Department Id" },
    "leave_type": {
      "type": "string",
      "enum": [
        "VACATION",
        "SICK",
        "CASUAL",
        "MATERNITY",
        "PATERNITY",
        "STUDY",
        "COMPASSIONATE",
        "PROFESSIONAL_APPOINTMENT",
        "BEREAVEMENT",
        "WITHOUT_PAY",
        "OTHER"
      ],
      "title": "LeaveType",
      "x-readme-ref-name": "LeaveType"
    },
    "start_date": { "type": "string", "format": "date", "title": "Start Date" },
    "end_date": { "type": "string", "format": "date", "title": "End Date" },
    "days_requested": {
      "anyOf": [
        { "type": "number" },
        { "type": "string", "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$" }
      ],
      "title": "Days Requested",
      "default": "0.0"
    },
    "days_with_pay": {
      "anyOf": [
        { "type": "number" },
        { "type": "string", "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$" }
      ],
      "title": "Days With Pay",
      "default": "0.0"
    },
    "days_without_pay": {
      "anyOf": [
        { "type": "number" },
        { "type": "string", "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$" }
      ],
      "title": "Days Without Pay",
      "default": "0.0"
    },
    "professional_appointment_subtype": {
      "anyOf": [
        {
          "type": "string",
          "enum": ["BANK", "MEDICAL", "LEGAL", "DENTAL"],
          "title": "ProfAppointmentType",
          "x-readme-ref-name": "ProfAppointmentType"
        },
        { "type": "null" }
      ]
    },
    "reason": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Reason"
    },
    "contact_phone": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Contact Phone"
    },
    "leave_address": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Leave Address"
    },
    "travel_from_date": {
      "anyOf": [{ "type": "string", "format": "date" }, { "type": "null" }],
      "title": "Travel From Date"
    },
    "travel_to_date": {
      "anyOf": [{ "type": "string", "format": "date" }, { "type": "null" }],
      "title": "Travel To Date"
    },
    "salary_in_advance": {
      "type": "boolean",
      "title": "Salary In Advance",
      "default": false
    },
    "requires_acting_appointment": {
      "type": "boolean",
      "title": "Requires Acting Appointment",
      "default": false
    },
    "acting_officer_id": {
      "anyOf": [{ "type": "string", "format": "uuid" }, { "type": "null" }],
      "title": "Acting Officer Id"
    },
    "expected_return_date": {
      "anyOf": [{ "type": "string", "format": "date" }, { "type": "null" }],
      "title": "Expected Return Date"
    },
    "co_approver_user_ids": {
      "items": { "type": "string", "format": "uuid" },
      "type": "array",
      "title": "Co Approver User Ids"
    },
    "as_draft": { "type": "boolean", "title": "As Draft", "default": false }
  },
  "type": "object",
  "required": ["department_id", "leave_type", "start_date", "end_date"],
  "title": "LeaveRequestCreate",
  "x-readme-ref-name": "LeaveRequestCreate"
}
