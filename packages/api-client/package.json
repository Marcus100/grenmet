{
  "name": "@grenmet/api-client",
  "version": "0.1.0",
  "description": "TypeScript client generated from FastAPI OpenAPI schema",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate": "kubb generate",
    "generate:watch": "kubb generate --watch",
    "generate:debug": "kubb generate --debug",
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "typescript": "^5.0.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "@grenmet/tsconfig": "workspace:*",
    "@kubb/cli": "^4.37.4",
    "@kubb/core": "^4.29.1",
    "@kubb/plugin-client": "^4.29.1",
    "@kubb/plugin-oas": "^4.29.1",
    "@kubb/plugin-react-query": "^4.29.1",
    "@kubb/plugin-ts": "^4.29.1",
    "@kubb/plugin-zod": "^4.29.1",
    "@kubb/react-fabric": "0.13.1",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "private": true,
  "dependencies": {
    "zod": "catalog:"
  }
}
