{
  "name": "@grenmet/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts"
    }
  },
  "peerDependencies": {
    "next": "*",
    "react": "*"
  },
  "devDependencies": {
    "@grenmet/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
