# =======================
# GNC-A (GeoNetCast) training repo — generated artifacts
# Python junk (__pycache__, .venv) and .ipynb_checkpoints are already
# ignored by the repo root and notebooks/.gitignore. This file covers the
# satellite data and rendered outputs the scripts produce when run.
# =======================

# Downloaded satellite data — scripts create these via os.makedirs("Samples").
# Ignore the contents (not the dir) so the committed links reference survives.
**/Samples/*
!**/Samples/Links_to_Download_Samples.txt

# Rendered figures — scripts create these via os.makedirs("Output")
Output/
**/Output/

# Root-level savefig outputs from the example scripts
Image_*.png
DCP_RGB.png

# Animation frames (Animation/HTML/.gitignore covers the HTML subdir; this
# catches frames written at the Animation/ root)
img_*.png

# Downloaded / generated data formats
*.nc
*.nc4
*.grib
*.grib2
*.tif
*.tiff
*.mp4
