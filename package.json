{
  "name": "grenmet-monorepo",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "dev": "turbo run dev --parallel",
    "start": "docker compose -f infra/docker/docker-compose.yml --profile tools up -d && docker compose -p grenmet-api -f apps/api/fastapi/docker-compose.yml up",
    "stop": "docker compose -p grenmet-api -f apps/api/fastapi/docker-compose.yml down --remove-orphans && docker compose -f infra/docker/docker-compose.yml --profile tools down",
    "reset": "docker compose -f infra/docker/docker-compose.yml --profile tools down -v && docker compose -f infra/docker/docker-compose.yml up postgres -d",
    "status": "docker compose -f infra/docker/docker-compose.yml --profile tools ps && docker compose -p grenmet-api -f apps/api/fastapi/docker-compose.yml ps",
    "dev:web": "turbo run dev --filter=@grenmet/web-*",
    "dev:web:wxwatch": "turbo run dev --filter=@grenmet/web-wxwatch",
    "dev:web:admin": "turbo run dev --filter=@grenmet/web-admin",
    "dev:web:wxproducts": "turbo run dev --filter=@grenmet/web-wxproducts",
    "dev:web:hurricane": "turbo run dev --filter=@grenmet/web-hurricaneplan",
    "dev:web:auth": "turbo run dev --filter=@grenmet/web-auth",
    "dev:web:spicewx": "turbo run dev --filter=@grenmet/web-spicewx",
    "dev:web:hr": "turbo run dev --filter=@grenmet/web-hr",
    "dev:web:salesbus": "turbo run dev --filter=@grenmet/web-salesbus",
    "dev:honoapi": "turbo run dev --filter=@grenmet/api-hono",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "check:ci": "turbo run check:ci",
    "type-check": "turbo run type-check",
    "fix": "pnpm dlx ultracite@latest fix",
    "generate:api-client": "turbo run generate --filter=@grenmet/api-client"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "turbo": "^2.9.6",
    "ultracite": "^7.6.0"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "@esbuild-kit/core-utils": "3.3.2",
      "@esbuild-kit/esm-loader": "2.6.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@react-jvectormap/core>react": "^19",
        "@react-jvectormap/core>react-dom": "^19",
        "@react-jvectormap/world>react": "^19",
        "@react-jvectormap/world>react-dom": "^19",
        "@tanstack/zod-form-adapter>zod": "^4",
        "@kubb/react-fabric": "0.13.1"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ]
  }
}
