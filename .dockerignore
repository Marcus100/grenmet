**/.next/
**/out/
**/dist/
**/.turbo/
**/build/
**/*.tsbuildinfo

# Test / coverage
**/coverage/
**/test-results/
**/playwright-report/
**/.playwright/

# Python
**/__pycache__/
**/*.pyc
**/.venv/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Env files
.env
.env.*
!.env.example

# Docs / CI (not needed in image)
*.md
.github/
docs/

# Unrelated services / data (not part of web builds)
notebooks/
geonetcast/
scripts/scrapy-wxwatch/
artifacts/

# Vendored ops apps — run on the host, never part of web images.
# Also keeps their env-file secrets (production.env, wis2box.env) out of
# every build context.
surface/
wis2box/

# Security
secrets/
*.pem
*.key

# Logs
*.log
logs/

# Turbo cache
.turbo/
