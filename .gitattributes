# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts
*.sh text eol=lf

# Force LF for Python files
*.py text eol=lf

# Force LF for YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Force LF for JSON files
*.json text eol=lf

# Force LF for Markdown files
*.md text eol=lf

# Force LF for environment files
*.env text eol=lf
.env.example text eol=lf
.env.*.example text eol=lf
.env.local.example text eol=lf
.env.staging.example text eol=lf
.env.production.example text eol=lf

# Force LF for configuration files
*.ini text eol=lf
*.toml text eol=lf
*.config.* text eol=lf

# Force LF for TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Force LF for CSS
*.css text eol=lf

# Force LF for MDX
*.mdx text eol=lf

# Force LF for Docker files
Dockerfile text eol=lf
Dockerfile.* text eol=lf
.dockerignore text eol=lf

# Force LF for SQL
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
