{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "lint": {
      "inputs": ["**/*.{ts,tsx,js,jsx,mjs,cjs}", "biome.jsonc", "biome.json"]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "check": {
      "inputs": ["**/*.{ts,tsx,js,jsx,mjs,cjs}", "biome.jsonc", "biome.json"]
    },
    "check:fix": {
      "cache": false
    },
    "check:ci": {
      "inputs": ["**/*.{ts,tsx,js,jsx,mjs,cjs}", "biome.jsonc", "biome.json"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.{ts,tsx}", "**/tsconfig*.json"]
    },
    "generate": {
      "cache": false,
      "outputs": ["src/gen/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "tests/**",
        "**/*.test.{ts,tsx}",
        "**/*.spec.{ts,tsx}"
      ]
    }
  }
}
