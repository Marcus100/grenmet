{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "check": {},
    "check:fix": {
      "cache": false
    },
    "check:ci": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "generate": {
      "cache": false
    }
  }
}
