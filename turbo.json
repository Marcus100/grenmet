{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "AUTH_APP_URL",
        "AUTH_API_URL",
        "AUTH_API_V1_STR",
        "SESSION_COOKIE_NAME",
        "SESSION_COOKIE_DOMAIN",
        "DB_URL",
        "DATABASE_URL",
        "RESEND_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "check": {},
    "check:fix": {
      "cache": false
    },
    "check:ci": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "generate": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
