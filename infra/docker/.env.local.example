# ===========================================
# Grenmet Shared Infrastructure — Local Development
# Variables for infra/docker/docker-compose.yml (Postgres, Adminer, shared tools)
# ===========================================
# Copy this file to .env.local and update values as needed:
#   cp .env.local.example .env.local
#
# ──────────────────────────────────────────────────────────────────────────────
# SETUP (two env files required for local dev)
#
#   1. cp infra/docker/.env.local.example   infra/docker/.env.local
#   2. cp apps/api/fastapi/.env.local.example  apps/api/fastapi/.env.local
#
#   infra/docker/.env.local          → read by infra docker-compose (Postgres, Adminer)
#   apps/api/fastapi/.env.local      → read by FastAPI docker-compose
# ──────────────────────────────────────────────────────────────────────────────

# ========= PostgreSQL — Root Superuser =========
# Used by Postgres itself and by init-databases.sh to create app databases.
# Must match POSTGRES_USER / POSTGRES_PASSWORD in apps/api/fastapi/.env.local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# ========= App Database (FastAPI) =========
# Created by infra/postgres/init-databases.sh on first volume init.
# Must match POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD in apps/api/fastapi/.env.local
APP_DB_NAME=app
APP_DB_USER=app
APP_DB_PASSWORD=changethis

# ========= wxwatch Database =========
# Created by infra/postgres/init-databases.sh on first volume init.
# Must match DATABASE_URL in apps/web/wxwatch/.env.local
WXWATCH_DB_NAME=wxwatch
WXWATCH_DB_USER=wxwatch
WXWATCH_DB_PASSWORD=changethis

# ========= wxproducts Database =========
# Created by infra/postgres/init-databases.sh on first volume init.
# Must match DATABASE_URL in apps/web/wxproducts/.env.local
WXPRODUCTS_DB_NAME=wxproducts
WXPRODUCTS_DB_USER=wxproducts
WXPRODUCTS_DB_PASSWORD=changethis

# ========= Adminer UI =========
# Theme for the Adminer database browser (http://localhost:8080)
# Available themes: https://www.adminer.org/en/plugins/#plugin-designs
ADMINER_DESIGN=pepa-linha-dark
