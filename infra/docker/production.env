# GrenMet — production non-secret deploy config (committed; single source of truth).
# Layered under the runtime .env.secrets written by .github/workflows/deploy.yml:
#   docker compose --env-file production.env --env-file .env.secrets -f docker-compose.deploy.yml
# Secrets NEVER go in this file. TAG/WEB_TAG are dynamic (release tag) and are
# written into .env.secrets by the workflow.

ENVIRONMENT=production
BASE_DOMAIN=barrels.gd
DOMAIN=api.barrels.gd
ROUTER_SUFFIX=

# ── weather.gd coexistence (see docs/weather-gd-golive.md) ──────────────────
# Active now (harmless before cutover): weather.gd hosts may be post-sign-in
# redirect targets, and weather.gd origins may call the API from the browser.
EXTRA_RETURN_HOSTS=,.weather.gd
# DORMANT — uncomment ONLY after weather.gd DNS points at the prod droplet.
# Enabling earlier makes Traefik request Let's Encrypt certs it cannot
# validate. Double quotes are required: they preserve the leading space.
#SPICEWX_EXTRA_HOSTS_RULE=" || Host(`weather.gd`) || Host(`www.weather.gd`)"
#API_EXTRA_HOSTS_RULE=" || Host(`api.weather.gd`)"
#HURRICANEPLAN_EXTRA_HOSTS_RULE=" || Host(`hurricane.weather.gd`)"

# Postgres (server-level; passwords come from .env.secrets)
POSTGRES_DB=app_prod
POSTGRES_SERVER=db
POSTGRES_PORT=5432
WXWATCH_DB_NAME=wxwatch
WXWATCH_DB_USER=wxwatch
WXPRODUCTS_DB_NAME=wxproducts
WXPRODUCTS_DB_USER=wxproducts
JANITORIAL_DB_NAME=janitorial
JANITORIAL_DB_USER=janitorial
TRANSPORT_DB_NAME=transport
TRANSPORT_DB_USER=transport
DB_HEALTH_START_PERIOD=30s

# Images
REGISTRY=ghcr.io
IMAGE_NAME=marcus100/grenmet
GHCR_OWNER=marcus100

# App config
PROJECT_NAME=Grenmet API
BACKEND_CORS_ORIGINS=https://auth.barrels.gd,https://admin.barrels.gd,https://hurricane.barrels.gd,https://spice.barrels.gd,https://weather.gd,https://www.weather.gd,https://hurricane.weather.gd
SESSION_COOKIE_DOMAIN=.barrels.gd
EMAILS_FROM_EMAIL=noreply@barrels.gd
FRONTEND_HOST=https://auth.barrels.gd
REDIS_URL=redis://redis:6379/0

# Docker object names — MUST match what already exists on the production droplet
# (created by the old docker-compose.prod.yml under project grenmet).
PGDATA_VOLUME=grenmet_pgdata
REDIS_VOLUME=grenmet_redis-data
CERTS_VOLUME=grenmet_traefik-certificates
