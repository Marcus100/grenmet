# GrenMet — staging non-secret deploy config (committed; single source of truth).
# Layered under the runtime .env.secrets written by .github/workflows/deploy.yml:
#   docker compose --env-file staging.env --env-file .env.secrets -f docker-compose.deploy.yml
# Secrets NEVER go in this file.

ENVIRONMENT=staging
BASE_DOMAIN=staging.barrels.gd
DOMAIN=api.staging.barrels.gd
ROUTER_SUFFIX=-staging

# Postgres (server-level; passwords come from .env.secrets)
POSTGRES_DB=app_staging
POSTGRES_SERVER=db
POSTGRES_PORT=5432
WXWATCH_DB_NAME=wxwatch_staging
WXWATCH_DB_USER=wxwatch
WXPRODUCTS_DB_NAME=wxproducts_staging
WXPRODUCTS_DB_USER=wxproducts
JANITORIAL_DB_NAME=janitorial_staging
JANITORIAL_DB_USER=janitorial
TRANSPORT_DB_NAME=transport_staging
TRANSPORT_DB_USER=transport
DB_HEALTH_START_PERIOD=60s

# Images
REGISTRY=ghcr.io
IMAGE_NAME=marcus100/grenmet
GHCR_OWNER=marcus100
TAG=staging
WEB_TAG=staging

# App config
PROJECT_NAME=Grenmet API
BACKEND_CORS_ORIGINS=https://auth.staging.barrels.gd,https://admin.staging.barrels.gd,https://hurricane.staging.barrels.gd,https://spice.staging.barrels.gd
SESSION_COOKIE_DOMAIN=.staging.barrels.gd
EMAILS_FROM_EMAIL=noreply@barrels.gd
FRONTEND_HOST=https://auth.staging.barrels.gd
REDIS_URL=redis://redis:6379/0

# Docker object names — MUST match what already exists on the staging droplet
# (created by the old docker-compose.staging.yml under project grenmet-staging).
PGDATA_VOLUME=grenmet-staging_pgdata-staging
REDIS_VOLUME=grenmet-staging_redis-data-staging
CERTS_VOLUME=grenmet-staging_traefik-certificates-staging
NETWORK_NAME=grenmet-staging_grenmet-staging

# Staging-only services (adminer)
COMPOSE_PROFILES=staging
