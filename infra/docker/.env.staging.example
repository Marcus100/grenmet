# ===========================================
# GrenMet — Staging Environment
# ===========================================
# Reference template for manual staging deploys.
# Copy to .env, fill in secrets, then run:
#   docker compose --env-file .env -f docker-compose.staging.yml -p grenmet-staging up -d
#
# In CI, this file is NOT used — the workflow generates .env dynamically.
# ===========================================

# ========= Environment Selection =========
ENVIRONMENT=staging

# ========= Project Identity =========
PROJECT_NAME=Grenmet API
STACK_NAME=grenmet-staging
COMPOSE_PROJECT_NAME=grenmet-staging

# ========= Domains and Hosts =========
DOMAIN=api.staging.barrels.gd
FRONTEND_HOST=https://auth.staging.barrels.gd

# ========= API Configuration =========
API_V1_STR=/api/v1

# CORS origins accepted by the FastAPI backend.
# Must include all web app origins that call the API.
BACKEND_CORS_ORIGINS=https://auth.staging.barrels.gd,https://admin.staging.barrels.gd,https://wxwatch.staging.barrels.gd,https://wxproducts.staging.barrels.gd,https://hurricane.staging.barrels.gd,https://spice.staging.barrels.gd,https://hr.staging.barrels.gd,https://sales.staging.barrels.gd

# ========= Security =========
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# JWT token expiration (minutes). Default: 8 days.
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Session token expiration (minutes). Short-lived exchange token.
SESSION_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Session cookie lifetime (days).
SESSION_EXPIRE_DAYS=30

# Bootstrap superuser — created on first prestart run.
FIRST_SUPERUSER=admin@barrels.gd
FIRST_SUPERUSER_PASSWORD=changethis

# ========= Session / Cookie =========
SESSION_COOKIE_NAME=grenmet_session
SESSION_COOKIE_DOMAIN=.staging.barrels.gd

# ========= Database (PostgreSQL) =========
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app_staging
POSTGRES_USER=app
POSTGRES_PASSWORD=changethis

# WxWatch database
WXWATCH_DB_NAME=wxwatch_staging
WXWATCH_DB_USER=wxwatch
WXWATCH_DB_PASSWORD=changethis
WXWATCH_DB_URL=postgresql://wxwatch:changethis@db:5432/wxwatch_staging

# WxProducts database
WXPRODUCTS_DB_NAME=wxproducts_staging
WXPRODUCTS_DB_USER=wxproducts
WXPRODUCTS_DB_PASSWORD=changethis
WXPRODUCTS_DB_URL=postgresql://wxproducts:changethis@db:5432/wxproducts_staging

# ========= Email Configuration =========
# Sender address used in all outgoing emails.
EMAILS_FROM_EMAIL=noreply@barrels.gd
EMAILS_FROM_NAME=Grenmet

# Resend API Key — if set, backend uses Resend. Otherwise falls back to SMTP.
RESEND_API_KEY=

# SMTP fallback (leave empty if using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
SMTP_SSL=False

# Password reset link expiry (hours)
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48

# Test recipient for /api/v1/utils/test-email/ endpoint
EMAIL_TEST_USER=test@barrels.gd

# ========= Observability =========
SENTRY_DSN=

# ========= Container Images =========
REGISTRY=ghcr.io
# IMAGE_NAME is <owner>/<repo>, e.g. euginwhint/grenmet
IMAGE_NAME=changethis
TAG=staging
GHCR_OWNER=changethis
WEB_TAG=staging

# ========= Traefik =========
# Let's Encrypt registration email
EMAIL=changethis@example.com
# Basic auth for Traefik dashboard: generate with htpasswd -nbB admin 'password'
USERNAME=admin
HASHED_PASSWORD=changethis

# ========= Web App Auth (passed to web services via compose) =========
AUTH_APP_URL=https://auth.staging.barrels.gd
AUTH_API_URL=https://api.staging.barrels.gd
AUTH_API_V1_STR=/api/v1
AUTH_ALLOWED_RETURN_HOSTS=.staging.barrels.gd
